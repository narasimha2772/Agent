# Core
ACP_SHARED_SECRET=change-me
DEFAULT_PUBLISH_MODE=preview
DB_PROVIDER=postgresql
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/acp
REDIS_URL=redis://localhost:6379

# Feature flags
ENABLE_AFFILIATE_BLOG_AGENT=true
ENABLE_NICHE_ADS_BLOG_AGENT=true
ENABLE_POD_AGENT=true
ENABLE_STOCK_MEDIA_AGENT=true
ENABLE_NEWSLETTER_AGENT=true
ENABLE_YOUTUBE_FACELESS_AGENT=true
ENABLE_MICRO_SAAS_AGENT=true
ENABLE_QA_FUNNEL_AGENT=true
ENABLE_EBOOK_COURSE_AGENT=true
ENABLE_RESEARCH_REPORTS_AGENT=true
ENABLE_PODCAST_AGENT=true
ENABLE_TEMPLATE_MARKET_AGENT=true
ENABLE_PLUGIN_EXTENSION_AGENT=true
ENABLE_LANGUAGE_LEARNING_AGENT=true
ENABLE_SOCIAL_AUTOMATION_AGENT=true
ENABLE_ARBITRAGE_AGENT=true
ENABLE_AI_TOOLS_DIRECTORY_AGENT=true
ENABLE_JOB_BOARD_AGENT=true
ENABLE_ONLINE_COURSE_COMMUNITY_AGENT=true
ENABLE_AI_CHATBOT_BUILDER_AGENT=true

# API keys (optional)
ALPHAVANTAGE_API_KEY=
COINGECKO_FREE=1
PEXELS_API_KEY=
UNSPLASH_ACCESS_KEY=
MAILJET_API_KEY=
MAILJET_SECRET_KEY=
YOUTUBE_API_KEY=
TWITTER_BEARER_TOKEN=
BLUESKY_APP_PASSWORD=
OPENAI_API_KEY=
STABILITY_API_KEY=
EXCHANGE_API_KEY=
